<!doctype html>
<html lang="no">
<head>
  <%- include("partials/head") %>
</head>
<body>
  <%- include("partials/header", { activeNav }) %>

  <main class="page-main">
    <div class="search-layout shell">
      <section class="page-heading">
        <div>
          <p class="eyebrow">Søk</p>
          <h1 class="page-heading__title"><%= query ? `Resultater for “${query}”` : "Søk i arkivet" %></h1>
          <p class="page-heading__intro">
            <%= query ? `${results.length} treff i databasen.` : "Skriv et søkebegrep for å finne artikler i FØNIKS-arkivet." %>
          </p>
        </div>
      </section>

      <% if (!query) { %>
        <div class="search-empty">
          Søket er lokalt koblet til SQLite-databasen og matcher på tittel, ingress og temamerke.
        </div>
      <% } else if (results.length === 0) { %>
        <div class="search-empty">
          Ingen artikler matchet “<%= query %>”. Prøv et bredere søk eller kortere nøkkelord.
        </div>
      <% } else { %>
        <section class="article-grid article-grid--listing">
          <% results.forEach((article) => { %>
            <%- include("partials/article-card", { article }) %>
          <% }) %>
        </section>
      <% } %>
    </div>
  </main>

  <%- include("partials/footer") %>
  <%- include("partials/search-overlay") %>
  <script src="/js/app.js"></script>
</body>
</html>
