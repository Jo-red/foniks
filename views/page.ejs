<!doctype html>
<html lang="no">
<head>
  <%- include("partials/head") %>
</head>
<body>
  <%- include("partials/header", { activeNav }) %>

  <main class="page-main">
    <div class="page-shell shell">
      <section class="page-heading">
        <div>
          <p class="eyebrow"><%= page.title %></p>
          <h1 class="page-heading__title"><%= page.title %></h1>
          <p class="page-heading__intro"><%= page.intro %></p>
        </div>
      </section>

      <section class="page-content-grid">
        <article class="page-content">
          <p class="page-content__intro"><%= page.intro %></p>
          <h2 class="page-content__title"><%= page.title %></h2>
          <div class="page-content__body"><%- page.body_html %></div>
          <div class="page-content__media">
            <img src="<%= page.image_url %>" alt="<%= page.title %>">
          </div>
          <a class="cta-link" href="<%= page.cta_url %>" target="_blank" rel="noopener noreferrer" style="margin-top: 24px;">
            <%= page.cta_label %>
          </a>
        </article>

        <aside class="page-sidebar">
          <p class="eyebrow">Nytt i arkivet</p>
          <h2 class="panel-heading">Les videre i FØNIKS.</h2>
          <p class="panel-copy">
            Statiske infosider fungerer bedre når de kobles tett til resten av innholdet.
          </p>

          <div class="story-list">
            <% highlights.recent.forEach((article, index) => { %>
              <%- include("partials/story-row", { article, index: index + 1, showExcerpt: false }) %>
            <% }) %>
          </div>
        </aside>
      </section>
    </div>
  </main>

  <%- include("partials/footer") %>
  <%- include("partials/search-overlay") %>
  <script src="/js/app.js"></script>
</body>
</html>
